# Скопируйте этот файл в .env и заполните реальными значениями.
# .env никогда не должен попадать в git (см. .gitignore).

# --- Telegram ---
TELEGRAM_BOT_TOKEN=

# --- GigaChat через ProxyAPI ---
PROXYAPI_KEY=
# ЗАГЛУШКА — уточнить точный путь эндпоинта в документации ProxyAPI (proxyapi.ru)
PROXYAPI_BASE_URL=https://api.proxyapi.ru/gigachat/v1/chat/completions
GIGACHAT_MODEL=GigaChat
# Зарезервировано на случай прямой интеграции со Sber без ProxyAPI (не используется сейчас)
GIGACHAT_CREDENTIALS=

# --- Внешняя система (CRM) ---
# Необязательно: если не задано, заявки только сохраняются локально в SQLite
CRM_WEBHOOK_URL=

# --- Сетевые настройки ---
REQUEST_TIMEOUT_SECONDS=18
RETRY_ATTEMPTS=3

# --- Хранилища ---
STATS_DB_PATH=data/stats.sqlite3
LEADS_DB_PATH=data/leads.sqlite3

# --- Поведение диалога ---
MANAGER_SLA_TEXT=в течение одного рабочего дня
CONSENT_PROMPT_AFTER_MESSAGES=4
